<?xml version="1.0"?>
<!--
  HAUV - starter URDF for RViz2.

  Frame: X forward, Y port, Z up. Origin on the pressure-tube axis, centred
  fore-aft. Matches the Fusion model exactly - every joint origin below was
  read straight out of the CAD, not measured off a drawing.

  Meshes are exported from Fusion in MILLIMETRES, hence scale="0.001 0.001 0.001"
  on every mesh. Removing that will make the vehicle 1000x too big.

  MESH PATHS use package://hauv_description/. Either
    (a) drop this folder into a ROS2 package called hauv_description, or
    (b) sed -i 's|package://hauv_description|file:///C:/Users/matma/Desktop/rov_ws - Copilot/Enclosure/model|' hauv.urdf
  for a quick standalone load.

  THRUSTERS are continuous joints about their own +X (the thrust axis), so
  publishing /joint_states will turn them. Caveat: t200.stl is the WHOLE
  thruster, so the duct turns with the rotor. To spin only the rotor, the
  propeller bodies need splitting out of the T200 STEP into their own mesh -
  a small extra export, not a redesign.

  Rotor direction is carried by the material: green = CW, blue = CCW, matching
  the diagonal pairing (T1/T4 CW, T2/T3 CCW, T5 CW, T6 CCW).
-->
<robot name="hauv">

  <material name="alu">      <color rgba="0.72 0.74 0.76 1.0"/></material>
  <material name="acrylic">  <color rgba="0.80 0.90 1.00 0.35"/></material>
  <material name="cw_green"> <color rgba="0.13 0.45 0.20 1.0"/></material>
  <material name="ccw_blue"> <color rgba="0.13 0.18 0.45 1.0"/></material>
  <material name="lightblue"><color rgba="0.45 0.70 0.90 1.0"/></material>
  <material name="pcb_green"><color rgba="0.10 0.35 0.15 1.0"/></material>
  <material name="dark">     <color rgba="0.20 0.20 0.22 1.0"/></material>
  <material name="grey">     <color rgba="0.55 0.55 0.58 1.0"/></material>

  <!-- ================= base_link: hull, mounts and internal payload ======
       These meshes were built directly in vehicle coordinates, so their
       vertices already carry the correct pose - origin is 0 0 0 for all. -->
  <link name="base_link">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hauv_description/meshes/main_tube.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="alu"/></visual>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hauv_description/meshes/cap_aft.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="alu"/></visual>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hauv_description/meshes/dome_fwd.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="acrylic"/></visual>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hauv_description/meshes/mount_fwd.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="alu"/></visual>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hauv_description/meshes/mount_aft.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="alu"/></visual>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hauv_description/meshes/tray.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="alu"/></visual>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hauv_description/meshes/dvl_head.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="dark"/></visual>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hauv_description/meshes/dvl_electronics.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="dark"/></visual>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hauv_description/meshes/upboard.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="pcb_green"/></visual>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hauv_description/meshes/esp32.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="pcb_green"/></visual>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hauv_description/meshes/battery_large_20Ah.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="lightblue"/></visual>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hauv_description/meshes/battery_small_1p2Ah.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="lightblue"/></visual>

    <!-- coarse hull collision: the pressure tube, axis along X -->
    <collision><origin xyz="-0.0226 0 0" rpy="0 1.5707963 0"/>
      <geometry><cylinder radius="0.0635" length="0.300"/></geometry></collision>

    <inertial>
      <origin xyz="-0.02 0 -0.01" rpy="0 0 0"/>
      <mass value="5.531"/>
      <inertia ixx="0.045" ixy="0" ixz="0" iyy="0.180" iyz="0" izz="0.180"/>
    </inertial>
  </link>

  <!-- ================= thrusters: continuous about local +X ============== -->

  <link name="t1_front_left">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hauv_description/meshes/t200.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="cw_green"/></visual>
  </link>
  <joint name="t1_front_left_joint" type="continuous">
    <parent link="base_link"/><child link="t1_front_left"/>
    <origin xyz="0.24760 0.09260 -0.01400" rpy="0 0 0.785398"/>
    <axis xyz="1 0 0"/>
  </joint>

  <link name="t2_front_right">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hauv_description/meshes/t200.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="ccw_blue"/></visual>
  </link>
  <joint name="t2_front_right_joint" type="continuous">
    <parent link="base_link"/><child link="t2_front_right"/>
    <origin xyz="0.24760 -0.09260 -0.01400" rpy="0 0 -0.785398"/>
    <axis xyz="1 0 0"/>
  </joint>

  <link name="t3_rear_left">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hauv_description/meshes/t200.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="ccw_blue"/></visual>
  </link>
  <joint name="t3_rear_left_joint" type="continuous">
    <parent link="base_link"/><child link="t3_rear_left"/>
    <origin xyz="-0.25240 0.09740 -0.01400" rpy="0 0 -0.785398"/>
    <axis xyz="1 0 0"/>
  </joint>

  <link name="t4_rear_right">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hauv_description/meshes/t200.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="cw_green"/></visual>
  </link>
  <joint name="t4_rear_right_joint" type="continuous">
    <parent link="base_link"/><child link="t4_rear_right"/>
    <origin xyz="-0.25240 -0.09740 -0.01400" rpy="0 0 0.785398"/>
    <axis xyz="1 0 0"/>
  </joint>

  <link name="t5_vert_front">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hauv_description/meshes/t200.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="cw_green"/></visual>
  </link>
  <joint name="t5_vert_front_joint" type="continuous">
    <parent link="base_link"/><child link="t5_vert_front"/>
    <origin xyz="0.30360 0 0.00440" rpy="0 -1.570796 -3.141593"/>
    <axis xyz="1 0 0"/>
  </joint>

  <link name="t6_vert_rear">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hauv_description/meshes/t200.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="ccw_blue"/></visual>
  </link>
  <joint name="t6_vert_rear_joint" type="continuous">
    <parent link="base_link"/><child link="t6_vert_rear"/>
    <origin xyz="-0.30640 0 0.00440" rpy="0 -1.570796 -3.141593"/>
    <axis xyz="1 0 0"/>
  </joint>

  <!-- ================= lights (fixed) ==================================
       The odd-looking origins are correct: the vendor Lumen mesh is not
       centred on its own origin (its local Y runs 372..409 mm), so the joint
       offset cancels that. Do not "tidy" these numbers. -->

  <link name="light_lower_left">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hauv_description/meshes/lumen.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="grey"/></visual>
  </link>
  <joint name="light_lower_left_joint" type="fixed">
    <parent link="base_link"/><child link="light_lower_left"/>
    <origin xyz="0.13630 0.11500 -0.49450" rpy="1.570796 0 -1.570796"/>
  </joint>

  <link name="light_lower_right">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hauv_description/meshes/lumen.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="grey"/></visual>
  </link>
  <joint name="light_lower_right_joint" type="fixed">
    <parent link="base_link"/><child link="light_lower_right"/>
    <origin xyz="0.13630 -0.07500 -0.49450" rpy="1.570796 0 -1.570796"/>
  </joint>

  <link name="light_upper_left">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hauv_description/meshes/lumen.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="grey"/></visual>
  </link>
  <joint name="light_upper_left_joint" type="fixed">
    <parent link="base_link"/><child link="light_upper_left"/>
    <origin xyz="0.13630 0.06500 -0.28580" rpy="1.570796 0 -1.570796"/>
  </joint>

  <link name="light_upper_right">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hauv_description/meshes/lumen.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="grey"/></visual>
  </link>
  <joint name="light_upper_right_joint" type="fixed">
    <parent link="base_link"/><child link="light_upper_right"/>
    <origin xyz="0.13630 -0.02500 -0.28580" rpy="1.570796 0 -1.570796"/>
  </joint>

  <!-- ================= sensors (fixed) ================================= -->

  <link name="subsonus">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hauv_description/meshes/subsonus.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="grey"/></visual>
  </link>
  <joint name="subsonus_joint" type="fixed">
    <parent link="base_link"/><child link="subsonus"/>
    <origin xyz="-0.04000 0 0.07860" rpy="1.570796 0 1.570796"/>
  </joint>

  <link name="bar30">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hauv_description/meshes/bar30.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="dark"/></visual>
  </link>
  <joint name="bar30_joint" type="fixed">
    <parent link="base_link"/><child link="bar30"/>
    <origin xyz="-0.17850 0 -0.09500" rpy="-1.570796 0 0"/>
  </joint>

  <link name="indicator">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hauv_description/meshes/indicator.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="dark"/></visual>
  </link>
  <joint name="indicator_joint" type="fixed">
    <parent link="base_link"/><child link="indicator"/>
    <origin xyz="-0.19000 0 0.02500" rpy="0 0 1.570796"/>
  </joint>

  <!-- ================= useful reference frames ========================= -->

  <link name="camera_link"/>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/><child link="camera_link"/>
    <origin xyz="0.1274 0 0" rpy="0 0 0"/>
  </joint>

  <link name="dvl_link"/>
  <joint name="dvl_joint" type="fixed">
    <parent link="base_link"/><child link="dvl_link"/>
    <origin xyz="-0.0850 0 -0.1083" rpy="0 0 0"/>
  </joint>

</robot>
