  <material name="dark"><color rgba="0.20 0.20 0.22 1.00"/></material>
  <material name="grey"><color rgba="0.55 0.55 0.58 1.00"/></material>

  <link name="base_link">
    <visual><origin xyz="-0.02525 0.00000 0.00000" rpy="0.000000 1.570796 0.000000"/>
