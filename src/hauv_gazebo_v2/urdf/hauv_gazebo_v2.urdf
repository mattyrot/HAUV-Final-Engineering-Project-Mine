<?xml version="1.0"?>
<!-- 5-inch hull, GENERATED by Enclosure/model/gen_urdf.py and then TRIMMED for
     Gazebo. The generator does not emit usable Gazebo physics; without the four
     edits below the vehicle sinks 4.2 kg negative, is nearly immovable, is
     rolling-unstable, and produces exactly zero forward thrust.
       1. base_link <volume> 0.008157 -> 0.012338 m3  (+0.1 kg positive at 13.610 kg)
       2. <center_of_volume> -0.02525 0 0 -> -0.04928 0 0.04413  (above and in line with CG)
       3. <velocity_decay> 0.20/0.30 -> 0.006/0.02  (Gazebo applies it per STEP)
       4. rear thruster yaw -+45 deg -> +-135 deg   (else forward thrust cancels)
     Re-derive these if the hull changes; do not copy the 4-inch numbers. -->
<!-- GENERATED by gen_urdf.py - edit PARAMS there, not this file.
     Gazebo Classic 11 (ROS2 Foxy). BR 5" series, 500 mm tube.
     buoyancy + thrust are real plugins; hydrodynamics is NOT - velocity_decay
     is crude isotropic damping, not added mass or quadratic drag. -->
<robot name="hauv">
  <material name="alu"><color rgba="0.72 0.74 0.76 1.00"/></material>
  <material name="acrylic"><color rgba="0.80 0.90 1.00 0.35"/></material>
