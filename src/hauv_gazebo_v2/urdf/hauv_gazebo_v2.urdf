    <origin xyz="-0.25000 0.14500 -0.02035" rpy="0.000000 1.570796 2.356195"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.005" friction="0.0"/>
  </joint>
  <gazebo reference="t3_rear_left"><material>Gazebo/Blue</material></gazebo>

  <link name="t4_rear_right">
    <visual><geometry><cylinder radius="0.04865" length="0.08800"/></geometry>
      <material name="cw_green"/></visual>
    <collision><geometry><cylinder radius="0.04865" length="0.08800"/></geometry></collision>
