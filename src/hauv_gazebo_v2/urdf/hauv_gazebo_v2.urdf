    <collision><origin xyz="-0.02525 0 0" rpy="0 1.570796 0"/>
      <geometry><cylinder radius="0.06935" length="0.50000"/></geometry></collision>
    <collision><origin xyz="0 0 -0.07600" rpy="0 0 0"/>
      <geometry><box size="0.70400 0.31000 0.01200"/></geometry></collision>
    <inertial>
      <origin xyz="-0.04928 0.00000 0.01113" rpy="0 0 0"/>
      <mass value="11.546"/>
      <inertia ixx="0.097617" ixy="0.000000" ixz="0.014928" iyy="0.430519" iyz="-0.000000" izz="0.406663"/>
    </inertial>
  </link>

  <gazebo reference="base_link">
    <material>Gazebo/Grey</material>
    <velocity_decay><linear>0.006</linear><angular>0.02</angular></velocity_decay>
  </gazebo>

  <link name="t1_front_left">
    <visual><geometry><cylinder radius="0.04865" length="0.08800"/></geometry>
      <material name="cw_green"/></visual>
    <collision><geometry><cylinder radius="0.04865" length="0.08800"/></geometry></collision>
    <inertial><mass value="0.344"/>
      <inertia ixx="0.000426" ixy="0" ixz="0" iyy="0.000426" iyz="0" izz="0.000407"/></inertial>
  </link>
  <joint name="t1_front_left_joint" type="continuous">
    <parent link="base_link"/><child link="t1_front_left"/>
    <origin xyz="0.25000 0.14500 -0.02035" rpy="0.000000 1.570796 0.785398"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.005" friction="0.0"/>
  </joint>
  <gazebo reference="t1_front_left"><material>Gazebo/Green</material></gazebo>

  <link name="t2_front_right">
    <visual><geometry><cylinder radius="0.04865" length="0.08800"/></geometry>
      <material name="ccw_blue"/></visual>
    <collision><geometry><cylinder radius="0.04865" length="0.08800"/></geometry></collision>
    <inertial><mass value="0.344"/>
      <inertia ixx="0.000426" ixy="0" ixz="0" iyy="0.000426" iyz="0" izz="0.000407"/></inertial>
  </link>
  <joint name="t2_front_right_joint" type="continuous">
