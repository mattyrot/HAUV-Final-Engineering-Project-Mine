    <origin xyz="-0.35200 0.00000 -0.01220" rpy="0.000000 0.000000 0.000000"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.005" friction="0.0"/>
  </joint>
  <gazebo reference="t6_vert_rear"><material>Gazebo/Blue</material></gazebo>

  <gazebo>
    <plugin name="buoyancy" filename="libBuoyancyPlugin.so">
      <fluid_density>1025</fluid_density>
      <link name="base_link">
        <center_of_volume>-0.04928 0 0.04413</center_of_volume>
        <volume>0.012338</volume>
      </link>
      <link name="t1_front_left"><center_of_volume>0 0 0</center_of_volume><volume>0.000173</volume></link>
      <link name="t2_front_right"><center_of_volume>0 0 0</center_of_volume><volume>0.000173</volume></link>
      <link name="t3_rear_left"><center_of_volume>0 0 0</center_of_volume><volume>0.000173</volume></link>
      <link name="t4_rear_right"><center_of_volume>0 0 0</center_of_volume><volume>0.000173</volume></link>
      <link name="t5_vert_front"><center_of_volume>0 0 0</center_of_volume><volume>0.000173</volume></link>
      <link name="t6_vert_rear"><center_of_volume>0 0 0</center_of_volume><volume>0.000173</volume></link>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="t1_force" filename="libgazebo_ros_force.so">
      <ros><namespace>/hauv</namespace><remapping>gazebo_ros_force:=thruster/t1</remapping></ros>
      <link_name>t1_front_left</link_name><force_frame>link</force_frame>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin name="t2_force" filename="libgazebo_ros_force.so">
      <ros><namespace>/hauv</namespace><remapping>gazebo_ros_force:=thruster/t2</remapping></ros>
      <link_name>t2_front_right</link_name><force_frame>link</force_frame>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin name="t3_force" filename="libgazebo_ros_force.so">
      <ros><namespace>/hauv</namespace><remapping>gazebo_ros_force:=thruster/t3</remapping></ros>
      <link_name>t3_rear_left</link_name><force_frame>link</force_frame>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin name="t4_force" filename="libgazebo_ros_force.so">
      <ros><namespace>/hauv</namespace><remapping>gazebo_ros_force:=thruster/t4</remapping></ros>
      <link_name>t4_rear_right</link_name><force_frame>link</force_frame>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin name="t5_force" filename="libgazebo_ros_force.so">
      <ros><namespace>/hauv</namespace><remapping>gazebo_ros_force:=thruster/t5</remapping></ros>
      <link_name>t5_vert_front</link_name><force_frame>link</force_frame>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin name="t6_force" filename="libgazebo_ros_force.so">
      <ros><namespace>/hauv</namespace><remapping>gazebo_ros_force:=thruster/t6</remapping></ros>
      <link_name>t6_vert_rear</link_name><force_frame>link</force_frame>
    </plugin>
  </gazebo>

  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/><child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/></joint>
  <gazebo reference="imu_link">
    <sensor name="bno055" type="imu"><always_on>true</always_on>
      <update_rate>50</update_rate>
      <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros><namespace>/hauv</namespace><remapping>~/out:=imu</remapping></ros>
      </plugin></sensor></gazebo>
  <link name="camera_link"/>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/><child link="camera_link"/>
    <origin xyz="0.22475 0 0" rpy="0 0 0"/></joint>
  <gazebo reference="camera_link">
    <sensor name="fwd_camera" type="camera"><always_on>true</always_on>
      <update_rate>15</update_rate>
      <camera><horizontal_fov>1.396</horizontal_fov>
        <image><width>640</width><height>480</height></image>
        <clip><near>0.05</near><far>30</far></clip></camera>
      <plugin name="camera_plugin" filename="libgazebo_ros_camera.so">
        <ros><namespace>/hauv</namespace></ros>
      </plugin></sensor></gazebo>
  <link name="dvl_link"/>
  <joint name="dvl_joint" type="fixed">
    <parent link="base_link"/><child link="dvl_link"/>
    <origin xyz="-0.08525 0 -0.11430" rpy="0 0 0"/></joint>
</robot>
